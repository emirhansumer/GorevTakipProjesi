@model List<KullaniciOzet>
@{
    ViewData["Title"] = "Kullanıcılar";
    var aktifId = Context.Session.GetKullaniciId();
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h2 class="mb-0"><i class="bi bi-people-fill me-2 text-primary"></i> Kullanıcılar</h2>
        <p class="text-muted mb-0 small">@Model.Count kullanıcı</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Admin Paneli
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Kullanıcı</th>
                    <th>E-posta</th>
                    <th class="text-center">Görev</th>
                    <th class="text-center">Kategori</th>
                    <th>Kayıt</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ozet in Model)
                {
                    var k = ozet.Kullanici;
                    var benMi = k.Id == aktifId;
                    <tr>
                        <td>
                            <span class="fw-semibold">@k.AdSoyad</span>
                            @if (k.IsAdmin)
                            {
                                <span class="badge bg-primary ms-1"><i class="bi bi-shield-fill"></i> Admin</span>
                            }
                            @if (benMi)
                            {
                                <span class="badge bg-secondary ms-1">Sen</span>
                            }
                        </td>
                        <td class="text-muted">@k.Email</td>
                        <td class="text-center"><span class="badge bg-light text-dark border">@ozet.GorevSayisi</span></td>
                        <td class="text-center"><span class="badge bg-light text-dark border">@ozet.KategoriSayisi</span></td>
                        <td class="text-muted small">@k.KayitTarihi.ToString("dd.MM.yyyy")</td>
                        <td class="text-end">
                            @if (benMi)
                            {
                                <span class="text-muted small fst-italic">—</span>
                            }
                            else
                            {
                                <form asp-action="AdminYetkiToggle" asp-route-id="@k.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(k.IsAdmin ? "btn-outline-secondary" : "btn-outline-primary")"
                                            title="@(k.IsAdmin ? "Admin yetkisini kaldır" : "Admin yap")">
                                        <i class="bi @(k.IsAdmin ? "bi-shield-slash" : "bi-shield-plus")"></i>
                                        @(k.IsAdmin ? "Yetkiyi al" : "Admin yap")
                                    </button>
                                </form>
                                <button type="button" class="btn btn-sm btn-outline-danger" title="Kullanıcıyı sil"
                                        onclick="GorevTakip.silOnayi('kullanici-sil-@k.Id', { text: '@Html.Raw(Html.Encode(k.AdSoyad)) ve TÜM görev/kategorileri silinecek. Emin misin?' })">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <form id="kullanici-sil-@k.Id" asp-action="KullaniciSil" asp-route-id="@k.Id" method="post" class="d-none">
                                    @Html.AntiForgeryToken()
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Sistem Yönetimi";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h2 class="mb-0">
            <i class="bi bi-shield-lock-fill me-2 text-primary"></i> Sistem Yönetimi
        </h2>
        <p class="text-muted mb-0">Sistem geneli özet ve yönetim.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Kullanicilar" class="btn btn-outline-primary">
            <i class="bi bi-people me-1"></i> Kullanıcılar
        </a>
        <a asp-action="Gorevler" class="btn btn-outline-primary">
            <i class="bi bi-list-task me-1"></i> Tüm Görevler
        </a>
        <a asp-action="Ayarlar" class="btn btn-outline-primary">
            <i class="bi bi-gear me-1"></i> Site Ayarları
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-toplam h-100">
            <div class="card-body">
                <div class="stat-label">Kullanıcı</div>
                <div class="stat-value">@Model.ToplamKullanici</div>
                <i class="bi bi-people-fill stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-bekleyen h-100">
            <div class="card-body">
                <div class="stat-label">Görev</div>
                <div class="stat-value">@Model.ToplamGorev</div>
                <i class="bi bi-list-check stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-tamamlanan h-100">
            <div class="card-body">
                <div class="stat-label">Kategori</div>
                <div class="stat-value">@Model.ToplamKategori</div>
                <i class="bi bi-bookmarks-fill stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card stat-iptal h-100">
            <div class="card-body">
                <div class="stat-label">Alt Görev</div>
                <div class="stat-value">@Model.ToplamAltGorev</div>
                <i class="bi bi-check2-square stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <span class="fw-semibold"><i class="bi bi-pie-chart me-1 text-primary"></i> Görev Durum Dağılımı</span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 260px;">
                @if (Model.ToplamGorev == 0)
                {
                    <span class="text-muted">Henüz görev yok.</span>
                }
                else
                {
                    <canvas id="durumChart" style="max-height: 240px;"></canvas>
                }
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <span class="fw-semibold"><i class="bi bi-bar-chart me-1 text-primary"></i> En Aktif Kullanıcılar (görev sayısı)</span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 260px;">
                @if (!Model.EnAktifKullanicilar.Any())
                {
                    <span class="text-muted">Henüz görevi olan kullanıcı yok.</span>
                }
                else
                {
                    <canvas id="aktifChart" style="max-height: 240px;"></canvas>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-person-plus me-1 text-primary"></i> Son Kayıt Olanlar</span>
        <a asp-action="Kullanicilar" class="small text-decoration-none">Tümü <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <tbody>
                @foreach (var ozet in Model.SonKullanicilar)
                {
                    <tr>
                        <td>
                            <a asp-action="KullaniciDetay" asp-route-id="@ozet.Kullanici.Id" class="gorev-baslik-link fw-semibold">@ozet.Kullanici.AdSoyad</a>
                            @if (ozet.Kullanici.Rol != KullaniciRol.Kullanici)
                            {
                                <span class="badge @ozet.Kullanici.Rol.BadgeClass() ms-1"><i class="bi @ozet.Kullanici.Rol.Ikon()"></i> @ozet.Kullanici.Rol.Etiket()</span>
                            }
                            @if (!ozet.Kullanici.Aktif)
                            {
                                <span class="badge bg-secondary ms-1">Pasif</span>
                            }
                            <div class="text-muted small">@ozet.Kullanici.Email</div>
                        </td>
                        <td class="text-end text-muted small">
                            <i class="bi bi-clock me-1"></i>@ozet.Kullanici.KayitTarihi.ToString("dd.MM.yyyy")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            if (typeof Chart === 'undefined') return;
            var eksenRenk = '#94a3b8';

            var durumEl = document.getElementById('durumChart');
            if (durumEl) {
                new Chart(durumEl, {
                    type: 'doughnut',
                    data: {
                        labels: ['Bekleyen', 'Tamamlanan', 'İptal'],
                        datasets: [{
                            data: [@Model.BekleyenGorev, @Model.TamamlananGorev, @Model.IptalGorev],
                            backgroundColor: ['#f59e0b', '#10b981', '#94a3b8'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom', labels: { color: eksenRenk, padding: 14 } } }
                    }
                });
            }

            var aktifEl = document.getElementById('aktifChart');
            if (aktifEl) {
                new Chart(aktifEl, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(Json.Serialize(Model.EnAktifKullanicilar.Select(x => x.Kullanici.AdSoyad))),
                        datasets: [{
                            label: 'Görev sayısı',
                            data: @Html.Raw(Json.Serialize(Model.EnAktifKullanicilar.Select(x => x.GorevSayisi))),
                            backgroundColor: '#6366f1',
                            borderRadius: 6,
                            maxBarThickness: 46
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { ticks: { color: eksenRenk }, grid: { display: false } },
                            y: { beginAtZero: true, ticks: { color: eksenRenk, precision: 0 }, grid: { color: 'rgba(148,163,184,0.15)' } }
                        }
                    }
                });
            }
        })();
    </script>
}

@model IEnumerable<Gorev>
@{
    var baslik = ViewBag.Baslik as string ?? "Görevlerim";
    var filtre = ViewBag.Filtre as string ?? "tumu";
    var kategoriler = ViewBag.Kategoriler as List<Kategori> ?? new List<Kategori>();
    var seciliKategoriId = ViewBag.SeciliKategoriId as int?;
    var kategorisizAktif = (bool)(ViewBag.Kategorisiz ?? false);
    ViewData["Title"] = baslik;

    var (emptyIcon, emptyText) = filtre switch
    {
        "bekleyen" => ("bi-hourglass", "Bekleyen görevin yok. Tebrikler!"),
        "tamamlanan" => ("bi-emoji-smile", "Henüz tamamlanan görevin yok."),
        _ => ("bi-clipboard-x", "Henüz görevin yok.")
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h2 class="mb-0">@baslik</h2>
        <p class="text-muted mb-0 small">@Model.Count() görev</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Yeni Görev
    </a>
</div>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <ul class="nav nav-pills">
        <li class="nav-item">
            <a class="nav-link @(filtre == "tumu" && !seciliKategoriId.HasValue ? "active" : "")" asp-action="Index">
                <i class="bi bi-list-ul me-1"></i> Tümü
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(filtre == "bekleyen" ? "active" : "")" asp-action="Bekleyen">
                <i class="bi bi-hourglass-split me-1"></i> Bekleyen
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(filtre == "tamamlanan" ? "active" : "")" asp-action="Tamamlanan">
                <i class="bi bi-check-circle me-1"></i> Tamamlanan
            </a>
        </li>
    </ul>

    @if (kategoriler.Any() && filtre == "tumu")
    {
        // Tek satırda göstereceğimiz maksimum kategori sayısı.
        // Fazlası "+N daha" dropdown'una düşer (hover ile açılır).
        const int gorunenLimit = 6;
        var gorunen = kategoriler.Take(gorunenLimit).ToList();
        var fazla = kategoriler.Skip(gorunenLimit).ToList();
        var seciliFazlada = fazla.Any(k => k.Id == seciliKategoriId);

        <div class="d-flex align-items-center gap-1 flex-nowrap kategori-filter-grup">
            <span class="kategori-ayrac" aria-hidden="true"></span>
            @foreach (var kat in gorunen)
            {
                var aktif = seciliKategoriId == kat.Id;
                <a asp-action="Index" asp-route-kategoriId="@kat.Id"
                   class="kategori-chip text-decoration-none @RenkHelper.ChipKoyuClass(kat.Renk) @(aktif ? "" : "opacity-75")"
                   style="background:@kat.Renk;">
                    @Html.KategoriIkon(kat.Ikon)
                    @kat.Ad
                </a>
            }

            @if (fazla.Any())
            {
                <div class="kategori-dropdown">
                    <button type="button"
                            class="kategori-daha-buton @(seciliFazlada ? "aktif" : "")"
                            title="@fazla.Count kategori daha">
                        <i class="bi bi-three-dots"></i>
                    </button>
                    <div class="kategori-dropdown-menu">
                        <div class="kategori-dropdown-baslik">Diğer kategoriler (@fazla.Count)</div>
                        @foreach (var kat in fazla)
                        {
                            var aktif = seciliKategoriId == kat.Id;
                            <a asp-action="Index" asp-route-kategoriId="@kat.Id"
                               class="kategori-dropdown-item @(aktif ? "aktif" : "")">
                                <span class="kategori-ikon-yuvarlak kategori-ikon-mini" style="background:@kat.Renk;">
                                    @Html.KategoriIkon(kat.Ikon)
                                </span>
                                <span class="kategori-dropdown-item-ad" title="@kat.Ad">@kat.Ad</span>
                            </a>
                        }
                    </div>
                </div>
            }

            <a asp-action="Index" asp-route-kategorisiz="true"
               class="kategori-chip kategori-chip-bos-stil text-decoration-none @(kategorisizAktif ? "" : "opacity-75")"
               title="Kategorisi olmayan görevler">
                <i class="bi bi-circle"></i> Kategorisiz
            </a>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body empty-state">
            <i class="bi @emptyIcon empty-icon"></i>
            <p class="mb-2">@emptyText</p>
            @if (filtre == "tumu")
            {
                <a asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> İlk görevini ekle
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 gorev-tablosu">
                <thead>
                    <tr>
                        <th>Görev</th>
                        <th class="tablo-kategori-sutun">Kategori</th>
                        <th>Öncelik</th>
                        <th>Durum</th>
                        <th>Bitiş</th>
                        <th>Oluşturma</th>
                        <th class="gorev-islemler">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gorev in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Detail" asp-route-id="@gorev.Id" class="gorev-baslik-link fw-semibold">
                                    @gorev.Baslik
                                </a>
                                @if (!string.IsNullOrWhiteSpace(gorev.Aciklama))
                                {
                                    <div class="text-muted small text-truncate" style="max-width:400px;">
                                        @gorev.Aciklama
                                    </div>
                                }
                            </td>
                            <td class="tablo-kategori-sutun">
                                <button type="button"
                                        class="kategori-chip-btn"
                                        data-gorev-id="@gorev.Id"
                                        data-mevcut-kategori-id="@(gorev.KategoriId?.ToString() ?? "")"
                                        title="Kategoriyi değiştir">
                                    @if (gorev.Kategori is not null)
                                    {
                                        <span class="kategori-chip @RenkHelper.ChipKoyuClass(gorev.Kategori.Renk)" style="background:@gorev.Kategori.Renk;">
                                            @Html.KategoriIkon(gorev.Kategori.Ikon)
                                            <span>@gorev.Kategori.Ad</span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="kategori-chip kategori-chip-bos-stil">
                                            <i class="bi bi-circle"></i>
                                            <span>Kategorisiz</span>
                                        </span>
                                    }
                                </button>
                            </td>
                            <td>
                                <span class="badge oncelik-badge @gorev.Oncelik.CssClass()">
                                    <i class="bi @gorev.Oncelik.Ikon() me-1"></i>@gorev.Oncelik.Etiket()
                                </span>
                            </td>
                            <td>
                                <span class="badge @gorev.Durum.CssClass()">
                                    <i class="bi @gorev.Durum.Ikon() me-1"></i>@gorev.Durum.Etiket()
                                </span>
                            </td>
                            <td class="gorev-tarih">
                                @if (gorev.BitisTarihi.HasValue)
                                {
                                    <span><i class="bi bi-calendar-event me-1 text-muted"></i>@gorev.BitisTarihi.Value.ToString("dd.MM.yyyy")</span>
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">Tarih yok</span>
                                }
                            </td>
                            <td class="text-muted small gorev-tarih">@gorev.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="gorev-islemler">
                                <a asp-action="Detail" asp-route-id="@gorev.Id" class="btn btn-sm btn-outline-secondary" title="Detay">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@gorev.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" title="Sil"
                                        onclick="GorevTakip.silOnayi('sil-form-@gorev.Id', { text: '@Html.Raw(Html.Encode(gorev.Baslik)) görevi silinecek. Emin misin?' })">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <form id="sil-form-@gorev.Id" asp-action="Delete" asp-route-id="@gorev.Id" method="post" class="d-none">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            // Sunucudan gelen kullanıcı kategorilerini JS'e taşı
            var kategoriler = @Html.Raw(Json.Serialize(kategoriler.Select(k => new { id = k.Id, ad = k.Ad, renk = k.Renk, ikon = string.IsNullOrWhiteSpace(k.Ikon) ? "bi-bookmark" : k.Ikon })));

            document.querySelectorAll('.kategori-chip-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var gorevId = btn.dataset.gorevId;
                    var mevcut = btn.dataset.mevcutKategoriId || null;
                    GorevTakip.gorevKategoriDegistir(gorevId, mevcut, kategoriler, function (yeni) {
                        // Chip'i güncelle (sayfayı yenilemeden)
                        var ic = btn.querySelector('.kategori-chip');
                        if (yeni.kategoriId) {
                            var kat = kategoriler.find(function (k) { return k.id === yeni.kategoriId; });
                            var ikon = (kat && kat.ikon) || 'bi-bookmark';
                            // Açık renk mi? hesaplayıp class ekle
                            var koyuClass = GorevTakip.arkaPlanAcikMi(yeni.renk) ? ' chip-koyu-text' : '';
                            ic.className = 'kategori-chip' + koyuClass;
                            ic.style.background = yeni.renk;
                            ic.innerHTML = '<i class="bi ' + ikon + '"></i><span>' + yeni.ad + '</span>';
                            btn.dataset.mevcutKategoriId = yeni.kategoriId;
                        } else {
                            ic.className = 'kategori-chip kategori-chip-bos-stil';
                            ic.style.background = '';
                            ic.innerHTML = '<i class="bi bi-circle"></i><span>Kategorisiz</span>';
                            btn.dataset.mevcutKategoriId = '';
                        }
                    });
                });
            });
        })();
    </script>
}

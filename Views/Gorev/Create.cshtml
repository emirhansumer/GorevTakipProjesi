@model GorevFormViewModel
@{
    ViewData["Title"] = "Yeni Görev";
}

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0">Yeni Görev</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post" novalidate>
                    <partial name="_GorevForm" model="Model" />

                    <hr class="my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i> Vazgeç
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

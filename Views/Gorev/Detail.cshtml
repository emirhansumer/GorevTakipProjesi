@model Gorev
@{
    ViewData["Title"] = "Görev Detayı";
}

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0">Görev Detayı</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <h3 class="card-title mb-0">@Model.Baslik</h3>
                    <div class="d-flex gap-2 flex-wrap">
                        @if (Model.Kategori is not null)
                        {
                            <span class="kategori-chip" style="background:@Model.Kategori.Renk;">
                                <i class="bi @(string.IsNullOrWhiteSpace(Model.Kategori.Ikon) ? "bi-bookmark-fill" : Model.Kategori.Ikon)"></i>@Model.Kategori.Ad
                            </span>
                        }
                        <span class="badge fs-6 oncelik-badge @Model.Oncelik.CssClass()">
                            <i class="bi @Model.Oncelik.Ikon() me-1"></i>@Model.Oncelik.Etiket()
                        </span>
                        <span class="badge fs-6 @Model.Durum.CssClass()">@Model.Durum.Etiket()</span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-calendar-event me-1"></i> Bitiş Tarihi
                            </div>
                            <div class="fs-5">
                                @if (Model.BitisTarihi.HasValue)
                                {
                                    @Model.BitisTarihi.Value.ToString("dd MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Belirtilmemiş</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-clock me-1"></i> Oluşturulma
                            </div>
                            <div class="fs-5">@Model.OlusturmaTarihi.ToString("dd MMMM yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <div class="text-muted small text-uppercase fw-semibold mb-2">
                        <i class="bi bi-card-text me-1"></i> Açıklama
                    </div>
                    @if (string.IsNullOrWhiteSpace(Model.Aciklama))
                    {
                        <p class="text-muted fst-italic mb-0">Bu görev için açıklama yok.</p>
                    }
                    else
                    {
                        <div class="bg-light rounded-3 p-3" style="white-space:pre-wrap;">@Model.Aciklama</div>
                    }
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-end gap-2 flex-wrap">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-list-ul me-1"></i> Listeye Dön
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i> Düzenle
                    </a>
                    <button type="button" class="btn btn-outline-danger"
                            onclick="GorevTakip.silOnayi('sil-form-detay', { text: '@Html.Raw(Html.Encode(Model.Baslik)) görevi silinecek. Emin misin?' })">
                        <i class="bi bi-trash me-1"></i> Sil
                    </button>
                    <form id="sil-form-detay" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

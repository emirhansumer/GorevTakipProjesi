@model Gorev
@{
    ViewData["Title"] = "Görev Detayı";
    var altToplam = Model.AltGorevler.Count;
    var altTamamlanan = Model.AltGorevler.Count(a => a.Tamamlandi);
    var altYuzde = altToplam == 0 ? 0 : (int)Math.Round((double)altTamamlanan * 100 / altToplam);
}

<div class="d-flex align-items-center mb-3">
    <a href="javascript:void(0)" onclick="GorevTakip.geriGit('/Gorev')" class="btn btn-sm btn-outline-secondary me-2" title="Geri">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0">Görev Detayı</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <h3 class="card-title mb-0">@Model.Baslik</h3>
                    <div class="d-flex gap-2 flex-wrap">
                        @if (Model.Kategori is not null)
                        {
                            <span class="kategori-chip @RenkHelper.ChipKoyuClass(Model.Kategori.Renk)" style="background:@Model.Kategori.Renk;">
                                @Html.KategoriIkon(Model.Kategori.Ikon)@Model.Kategori.Ad
                            </span>
                        }
                        <span class="badge fs-6 oncelik-badge @Model.Oncelik.CssClass()">
                            <i class="bi @Model.Oncelik.Ikon() me-1"></i>@Model.Oncelik.Etiket()
                        </span>
                        <span class="badge fs-6 @Model.Durum.CssClass()">
                            <i class="bi @Model.Durum.Ikon() me-1"></i>@Model.Durum.Etiket()
                        </span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-calendar-event me-1"></i> Bitiş Tarihi
                            </div>
                            <div class="fs-5">
                                @if (Model.BitisTarihi.HasValue)
                                {
                                    @Model.BitisTarihi.Value.ToString("dd MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Belirtilmemiş</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-clock me-1"></i> Oluşturulma
                            </div>
                            <div class="fs-5">@Model.OlusturmaTarihi.ToString("dd MMMM yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <div class="text-muted small text-uppercase fw-semibold mb-2">
                        <i class="bi bi-card-text me-1"></i> Açıklama
                    </div>
                    @if (string.IsNullOrWhiteSpace(Model.Aciklama))
                    {
                        <p class="text-muted fst-italic mb-0">Bu görev için açıklama yok.</p>
                    }
                    else
                    {
                        <div class="bg-light rounded-3 p-3" style="white-space:pre-wrap;">@Model.Aciklama</div>
                    }
                </div>

                <hr class="my-4">

                <div class="alt-gorev-bolumu" data-gorev-id="@Model.Id">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small text-uppercase fw-semibold">
                            <i class="bi bi-list-check me-1"></i> Alt Görevler
                        </div>
                        <span class="alt-gorev-sayac badge rounded-pill @(altToplam > 0 && altTamamlanan == altToplam ? "tamam" : "")">
                            <span class="ag-tamamlanan">@altTamamlanan</span> / <span class="ag-toplam">@altToplam</span>
                        </span>
                    </div>

                    <div class="alt-gorev-progress mb-3 @(altToplam == 0 ? "d-none" : "")">
                        <div class="alt-gorev-progress-bar" style="width:@altYuzde%"></div>
                    </div>

                    <ul class="alt-gorev-listesi" id="altGorevListesi">
                        @foreach (var alt in Model.AltGorevler)
                        {
                            <li class="alt-gorev-madde @(alt.Tamamlandi ? "tamamlandi" : "")" data-alt-id="@alt.Id">
                                <span class="ag-tut" title="Sürükle"><i class="bi bi-grip-vertical"></i></span>
                                <label class="ag-check">
                                    <input type="checkbox" @(alt.Tamamlandi ? "checked" : "") />
                                    <span class="ag-kutu"><i class="bi bi-check-lg"></i></span>
                                </label>
                                <span class="ag-metin">@alt.Metin</span>
                                <button type="button" class="ag-sil" title="Sil"><i class="bi bi-x-lg"></i></button>
                            </li>
                        }
                    </ul>

                    <div class="alt-gorev-bos @(altToplam > 0 ? "d-none" : "")">
                        <i class="bi bi-check2-square"></i>
                        <span>Henüz alt görev yok. Aşağıdan madde ekleyebilirsin.</span>
                    </div>

                    <div class="input-group alt-gorev-ekle mt-2">
                        <span class="input-group-text"><i class="bi bi-plus-lg"></i></span>
                        <input type="text" class="form-control alt-gorev-input" maxlength="200"
                               placeholder="Yeni madde yaz ve Enter'a bas…" autocomplete="off" />
                        <button type="button" class="btn btn-primary alt-gorev-ekle-btn">
                            <i class="bi bi-plus-lg d-sm-none"></i><span class="d-none d-sm-inline">Ekle</span>
                        </button>
                    </div>
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-end gap-2 flex-wrap">
                    <a href="javascript:void(0)" onclick="GorevTakip.geriGit('/Gorev')" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Geri
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i> Düzenle
                    </a>
                    <button type="button" class="btn btn-outline-danger"
                            onclick="GorevTakip.silOnayi('sil-form-detay', { text: '@Html.Raw(Html.Encode(Model.Baslik)) görevi silinecek. Emin misin?' })">
                        <i class="bi bi-trash me-1"></i> Sil
                    </button>
                    <form id="sil-form-detay" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

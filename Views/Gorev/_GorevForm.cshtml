@model GorevFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

<input asp-for="Id" type="hidden" />

<div class="mb-3">
    <label asp-for="Baslik" class="form-label">
        <i class="bi bi-card-heading me-1 text-muted"></i> Başlık
    </label>
    <input asp-for="Baslik" class="form-control" autofocus placeholder="Görev başlığı..." />
    <span asp-validation-for="Baslik" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="Aciklama" class="form-label">
        <i class="bi bi-card-text me-1 text-muted"></i> Açıklama
    </label>
    <textarea asp-for="Aciklama" class="form-control" rows="4" placeholder="Görev hakkında detaylar..."></textarea>
    <span asp-validation-for="Aciklama" class="text-danger small"></span>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="BitisTarihi" class="form-label">
            <i class="bi bi-calendar-event me-1 text-muted"></i> Bitiş Tarihi
        </label>
        <input asp-for="BitisTarihi" class="form-control" />
        <span asp-validation-for="BitisTarihi" class="text-danger small"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="Durum" class="form-label">
            <i class="bi bi-tag me-1 text-muted"></i> Durum
        </label>
        <select asp-for="Durum" class="form-select"
                asp-items="Html.GetEnumSelectList<GorevTakip.Models.GorevDurum>()">
        </select>
        <span asp-validation-for="Durum" class="text-danger small"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="Oncelik" class="form-label">
            <i class="bi bi-flag me-1 text-muted"></i> Öncelik
        </label>
        <select asp-for="Oncelik" class="form-select"
                asp-items="Html.GetEnumSelectList<GorevTakip.Models.Oncelik>()">
        </select>
        <span asp-validation-for="Oncelik" class="text-danger small"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="KategoriId" class="form-label">
        <i class="bi bi-bookmark me-1 text-muted"></i> Kategori
    </label>
    <div class="input-group">
        <select asp-for="KategoriId" class="form-select" id="kategoriSelect">
            <option value="">— Kategorisiz —</option>
            @if (Model.KullaniciKategorileri is not null)
            {
                foreach (var kategori in Model.KullaniciKategorileri)
                {
                    <option value="@kategori.Id" data-renk="@kategori.Renk">@kategori.Ad</option>
                }
            }
        </select>
        <button type="button" class="btn btn-outline-primary" id="yeniKategoriBtn" title="Yeni kategori ekle">
            <i class="bi bi-plus-lg"></i>
        </button>
    </div>
    <span asp-validation-for="KategoriId" class="text-danger small"></span>
    <small class="text-muted">
        <i class="bi bi-info-circle me-1"></i>
        Hızlı kategori oluşturmak için "+" butonuna bas.
    </small>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var btn = document.getElementById('yeniKategoriBtn');
        var select = document.getElementById('kategoriSelect');
        if (btn && select) {
            btn.addEventListener('click', function () {
                GorevTakip.yeniKategoriEkle(function (yeni) {
                    var opt = document.createElement('option');
                    opt.value = yeni.id;
                    opt.textContent = yeni.ad;
                    opt.dataset.renk = yeni.renk;
                    opt.selected = true;
                    select.appendChild(opt);
                });
            });
        }
    });
</script>

@{
    ViewData["Title"] = "Bakımda";
}

<div class="text-center py-5">
    <div class="mb-3">
        <i class="bi bi-cone-striped text-warning" style="font-size: 4.5rem;"></i>
    </div>
    <h2 class="mb-2">Site şu an bakımda</h2>
    <p class="text-muted mb-4">
        Kısa bir bakım çalışması yapıyoruz. Lütfen biraz sonra tekrar dene.<br />
        Anlayışın için teşekkürler.
    </p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
        <i class="bi bi-box-arrow-in-right me-1"></i> Giriş ekranına git
    </a>
</div>

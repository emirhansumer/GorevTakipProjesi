@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var girisYapildi = session?.GirisYapildiMi() ?? false;
    var adSoyad = session?.GetAdSoyad();
    var routeData = ViewContext.RouteData.Values;
    var aktifController = routeData["controller"]?.ToString();
    var aktifAction = routeData["action"]?.ToString();

    string NavClass(string controller, params string[] actions)
    {
        if (aktifController != controller) return "nav-link";
        if (actions.Length == 0 || actions.Contains(aktifAction)) return "nav-link active";
        return "nav-link";
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Görev Takip</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GorevTakip.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-check2-square me-2 fs-4"></i>
                    Görev Takip
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        @if (girisYapildi)
                        {
                            <li class="nav-item">
                                <a class="@NavClass("Home", "Index")" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("Gorev", "Index")" asp-controller="Gorev" asp-action="Index">
                                    <i class="bi bi-list-check me-1"></i> Görevlerim
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("Gorev", "Bekleyen")" asp-controller="Gorev" asp-action="Bekleyen">
                                    <i class="bi bi-hourglass-split me-1"></i> Bekleyen
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("Gorev", "Tamamlanan")" asp-controller="Gorev" asp-action="Tamamlanan">
                                    <i class="bi bi-check-circle me-1"></i> Tamamlanan
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (girisYapildi)
                        {
                            <li class="nav-item">
                                <a class="@NavClass("Account", "Profile")" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-person-circle me-1"></i> @adSoyad
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link">
                                        <i class="bi bi-box-arrow-right me-1"></i> Çıkış
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Giriş Yap
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i> Kayıt Ol
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container pb-4">
        @if (TempData["Basari"] is string basari)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div>@basari</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Hata"] is string hata)
        {
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <div>@hata</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer mt-auto">
        <div class="container py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; 2026 - Görev Takip Sistemi</span>
            <span class="small">
                <i class="bi bi-code-slash me-1"></i> ASP.NET Core MVC + EF Core + SQLite
            </span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

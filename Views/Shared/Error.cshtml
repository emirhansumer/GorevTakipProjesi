@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-5 text-center">
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
                </div>
                <h2 class="mb-2">Bir şeyler yanlış gitti</h2>
                <p class="text-muted">Beklenmeyen bir hata oluştu. Tekrar denemek ister misin?</p>

                @if (Model.ShowRequestId)
                {
                    <p class="text-muted small">
                        <strong>İstek ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }

                <div class="d-flex justify-content-center gap-2 mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-house me-1"></i> Ana Sayfaya Dön
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Geri Git
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

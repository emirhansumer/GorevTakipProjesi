@model List<ProjeOzetViewModel>
@{
    ViewData["Title"] = "Projelerim";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h2 class="mb-0"><i class="bi bi-kanban me-2 text-primary"></i> Projelerim</h2>
        <p class="text-muted mb-0 small">Liderlik ettiğin @Model.Count proje</p>
    </div>
    <a asp-action="Olustur" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Yeni Proje</a>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body empty-state">
            <i class="bi bi-kanban empty-icon"></i>
            <p class="mb-2">Henüz bir projen yok.</p>
            <a asp-action="Olustur" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i> İlk projeni oluştur</a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="mb-1">@p.Proje.Ad</h5>
                        <p class="text-muted small flex-grow-1">@(string.IsNullOrWhiteSpace(p.Proje.Aciklama) ? "—" : p.Proje.Aciklama)</p>
                        <div class="d-flex gap-3 small text-muted mb-2">
                            <span><i class="bi bi-people me-1"></i>@p.UyeSayisi üye</span>
                            <span><i class="bi bi-list-check me-1"></i>@p.GorevSayisi görev</span>
                        </div>
                        <div class="progress mb-1" style="height: 7px;">
                            <div class="progress-bar bg-success" style="width:@p.Yuzde%"></div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">%@p.Yuzde tamam (@p.TamamlananGorev/@p.GorevSayisi)</span>
                            <a asp-action="Detay" asp-route-id="@p.Proje.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-gear me-1"></i> Yönet
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

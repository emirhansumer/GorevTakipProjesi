@model Proje
@{
    ViewData["Title"] = "Yeni Proje";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0"><i class="bi bi-plus-circle me-2 text-primary"></i> Yeni Proje</h2>
</div>

<div class="card shadow-sm" style="max-width: 640px;">
    <div class="card-body">
        <form asp-action="Olustur" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="mb-3">
                <label asp-for="Ad" class="form-label">Proje Adı</label>
                <input asp-for="Ad" class="form-control" placeholder="Örn. Web Sitesi Yenileme" autofocus />
                <span asp-validation-for="Ad" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Aciklama" class="form-label">Açıklama (isteğe bağlı)</label>
                <textarea asp-for="Aciklama" class="form-control" rows="3" placeholder="Proje hakkında kısa bilgi…"></textarea>
                <span asp-validation-for="Aciklama" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Oluştur</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

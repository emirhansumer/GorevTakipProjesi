@model ProfileViewModel
@{
    ViewData["Title"] = "Profil";
    var bashar = string.IsNullOrEmpty(Model.AdSoyad) ? "?" : Model.AdSoyad.Substring(0, 1).ToUpper();
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm mb-3">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4 flex-wrap gap-3">
                    <div class="profile-avatar">@bashar</div>
                    <div>
                        <h3 class="mb-0">@Model.AdSoyad</h3>
                        <div class="text-muted">
                            <i class="bi bi-envelope me-1"></i> @Model.Email
                        </div>
                    </div>
                    <div class="ms-auto">
                        <span class="badge bg-success">
                            <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>
                            @(Model.SessionAktif ? "Aktif Oturum" : "Pasif")
                        </span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-person-badge me-1"></i> Kullanıcı ID
                            </div>
                            <div class="fs-5">#@Model.KullaniciId</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-calendar-plus me-1"></i> Kayıt Tarihi
                            </div>
                            <div class="fs-5">@Model.KayitTarihi.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-collection me-1"></i> Toplam Görev
                            </div>
                            <div class="fs-5">@Model.ToplamGorev görev</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-shield-check me-1"></i> Session ID
                            </div>
                            <code class="small text-break">@Model.SessionId</code>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        Oturum bilgileri bu cihaza özeldir. Çıkış yaparak güvenliğini sağla.
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-box-arrow-right me-1"></i> Çıkış Yap
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

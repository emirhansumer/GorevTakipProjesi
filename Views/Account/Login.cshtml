@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="auth-wrapper">
    <div class="row w-100 g-4 align-items-stretch" style="max-width: 980px;">
        <div class="col-md-6 d-none d-md-block">
            <div class="auth-hero h-100">
                <h1>Görevlerini daha verimli yönet</h1>
                <p class="opacity-75 mb-4">Günlük işlerini düzenle, tamamlananları işaretle ve tüm hedeflerini tek yerden takip et.</p>

                <div class="hero-feature"><i class="bi bi-check2-circle"></i><span>Bekleyen ve tamamlanan görev takibi</span></div>
                <div class="hero-feature"><i class="bi bi-shield-lock"></i><span>Kullanıcıya özel güvenli veri</span></div>
                <div class="hero-feature"><i class="bi bi-graph-up"></i><span>Anlık istatistik panosu</span></div>
                <div class="hero-feature"><i class="bi bi-phone"></i><span>Mobil uyumlu arayüz</span></div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="auth-card h-100">
                <div class="text-center mb-4">
                    <i class="bi bi-check2-square text-primary" style="font-size: 2.5rem;"></i>
                    <h3 class="mt-2">Giriş Yap</h3>
                    <p class="text-muted small mb-0">Hesabına giriş yaparak görevlerine devam et</p>
                </div>

                @if (TempData["Mesaj"] is string mesaj)
                {
                    <div class="alert alert-success py-2 d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-2"></i> @mesaj
                    </div>
                }

                <form asp-action="Login" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" autocomplete="email" placeholder="ornek@mail.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sifre" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                            <input asp-for="Sifre" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Sifre" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-2">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Giriş Yap
                    </button>
                </form>

                <div class="text-center mt-3">
                    <small class="text-muted">Hesabın yok mu? <a asp-action="Register" class="fw-semibold">Kayıt ol</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model IEnumerable<GorevTakip.Controllers.KategoriController.KategoriIstatistik>
@{
    ViewData["Title"] = "Kategorilerim";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h2 class="mb-0">Kategorilerim</h2>
        <p class="text-muted mb-0 small">@Model.Count() kategori</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Yeni Kategori
    </a>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body empty-state">
            <i class="bi bi-bookmarks empty-icon"></i>
            <p class="mb-2">Henüz kategori oluşturmadın.</p>
            <a asp-action="Create" class="btn btn-sm btn-primary">
                <i class="bi bi-plus-lg me-1"></i> İlk kategorini ekle
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var istatistik in Model)
        {
            var kategori = istatistik.Kategori;
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="kategori-dot" style="background:@kategori.Renk;"></span>
                            <h5 class="mb-0 ms-2 flex-grow-1">@kategori.Ad</h5>
                        </div>

                        @if (istatistik.Toplam == 0)
                        {
                            <div class="text-muted small mb-3">
                                <i class="bi bi-info-circle me-1"></i> Bu kategoride henüz görev yok
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-1 small">
                                <span class="text-muted">
                                    <i class="bi bi-check2-circle me-1"></i>
                                    @istatistik.Tamamlanan / @istatistik.Toplam tamamlandı
                                </span>
                                <span class="fw-semibold" style="color:@kategori.Renk;">%@istatistik.Yuzde</span>
                            </div>
                            <div class="progress mb-3" style="height:6px;">
                                <div class="progress-bar"
                                     role="progressbar"
                                     style="width:@istatistik.Yuzde%; background:@kategori.Renk;"
                                     aria-valuenow="@istatistik.Yuzde"
                                     aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <a asp-controller="Gorev" asp-action="Index" asp-route-kategoriId="@kategori.Id"
                               class="btn btn-sm btn-outline-secondary flex-fill" title="Görevleri gör">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@kategori.Id" class="btn btn-sm btn-outline-primary flex-fill">
                                <i class="bi bi-pencil me-1"></i> Düzenle
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    onclick="GorevTakip.silOnayi('kategori-sil-@kategori.Id', { text: '@Html.Raw(Html.Encode(kategori.Ad)) kategorisi silinecek. Bu kategorideki görevler kategorisiz hale gelecek.' })">
                                <i class="bi bi-trash"></i>
                            </button>
                            <form id="kategori-sil-@kategori.Id" asp-action="Delete" asp-route-id="@kategori.Id" method="post" class="d-none">
                                @Html.AntiForgeryToken()
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@model KategoriFormViewModel

@{
    var renkler = new[]
    {
        "#6366f1", "#ec4899", "#10b981", "#f59e0b", "#ef4444",
        "#06b6d4", "#8b5cf6", "#f97316", "#14b8a6", "#64748b"
    };

    var ikonlar = new[]
    {
        "bi-bookmark", "bi-book", "bi-briefcase", "bi-house",
        "bi-heart", "bi-cart", "bi-cup-hot", "bi-airplane",
        "bi-controller", "bi-music-note", "bi-camera", "bi-code-slash",
        "bi-lightbulb", "bi-flag", "bi-star", "bi-gem"
    };
}

<div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

<input asp-for="Id" type="hidden" />

<div class="mb-3">
    <label asp-for="Ad" class="form-label">
        <i class="bi bi-tag me-1 text-muted"></i> Kategori Adı
    </label>
    <input asp-for="Ad" class="form-control" autofocus placeholder="Örn: Okul, İş, Kişisel..." />
    <span asp-validation-for="Ad" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label class="form-label">
        <i class="bi bi-palette me-1 text-muted"></i> Renk
    </label>
    <input asp-for="Renk" type="hidden" id="renkInput" />
    <div class="renk-paleti d-flex flex-wrap gap-2 align-items-center">
        @foreach (var renk in renkler)
        {
            var aktif = string.Equals(Model.Renk, renk, StringComparison.OrdinalIgnoreCase);
            <button type="button"
                    class="renk-secenek @(aktif ? "aktif" : "")"
                    data-renk="@renk"
                    style="background:@renk;"
                    title="@renk">
                @if (aktif)
                {
                    <i class="bi bi-check-lg"></i>
                }
            </button>
        }
        <label class="renk-secenek renk-ozel ms-1" title="Özel renk seç">
            <i class="bi bi-eyedropper"></i>
            <input type="color" id="ozelRenk" value="@Model.Renk" />
        </label>
        <span id="renkHex" class="font-monospace text-muted ms-2 small">@Model.Renk</span>
    </div>
    <span asp-validation-for="Renk" class="text-danger small d-block mt-1"></span>
</div>

<div class="mb-3">
    <label class="form-label">
        <i class="bi bi-emoji-smile me-1 text-muted"></i> İkon
    </label>
    <input asp-for="Ikon" type="hidden" id="ikonInput" />
    <div class="ikon-paleti d-flex flex-wrap gap-2">
        @foreach (var ikon in ikonlar)
        {
            var aktif = string.Equals(Model.Ikon, ikon, StringComparison.OrdinalIgnoreCase);
            <button type="button"
                    class="ikon-secenek @(aktif ? "aktif" : "")"
                    data-ikon="@ikon"
                    title="@ikon">
                <i class="bi @ikon"></i>
            </button>
        }
    </div>
    <span asp-validation-for="Ikon" class="text-danger small d-block mt-1"></span>
</div>

<script>
    (function () {
        // Renk paleti
        var renkInput = document.getElementById('renkInput');
        var hexLabel = document.getElementById('renkHex');
        var ozelRenk = document.getElementById('ozelRenk');
        var renkBtns = document.querySelectorAll('.renk-secenek[data-renk]');

        function setRenk(renk) {
            renkInput.value = renk;
            hexLabel.textContent = renk;
            ozelRenk.value = renk;
            renkBtns.forEach(function (b) {
                var match = b.dataset.renk && b.dataset.renk.toLowerCase() === renk.toLowerCase();
                b.classList.toggle('aktif', match);
                var ic = b.querySelector('i');
                if (match && !ic) {
                    var i = document.createElement('i');
                    i.className = 'bi bi-check-lg';
                    b.appendChild(i);
                } else if (!match && ic) {
                    b.removeChild(ic);
                }
            });
        }
        renkBtns.forEach(function (b) {
            b.addEventListener('click', function () { setRenk(b.dataset.renk); });
        });
        ozelRenk.addEventListener('input', function () { setRenk(ozelRenk.value); });

        // İkon paleti
        var ikonInput = document.getElementById('ikonInput');
        var ikonBtns = document.querySelectorAll('.ikon-secenek');
        ikonBtns.forEach(function (b) {
            b.addEventListener('click', function () {
                ikonInput.value = b.dataset.ikon;
                ikonBtns.forEach(function (x) { x.classList.remove('aktif'); });
                b.classList.add('aktif');
            });
        });
    })();
</script>
